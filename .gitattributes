# Auto detect text files and perform LF normalization
* text=auto

# Source code
*.cpp       text diff=cpp
*.h         text diff=cpp
*.hpp       text diff=cpp
*.c         text diff=c
*.cmake     text
*.txt       text
*.md        text diff=markdown
*.json      text
*.yaml      text
*.yml       text
*.qml       text linguist-detectable
*.qrc       text
*.glsl      text
*.vert      text
*.frag      text
*.comp      text

# Binary
*.spv       binary
*.png       binary
*.jpg       binary
*.jpeg      binary
*.bmp       binary
*.tga       binary
*.dds       binary
*.ktx       binary
*.ico       binary
*.ttf       binary
*.otf       binary
